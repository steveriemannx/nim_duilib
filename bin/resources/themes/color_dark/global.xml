<?xml version="1.0" encoding="UTF-8"?>
<Global>
    <!-- 主题基础配置：Win11 25H2 深色主题 | 类型为颜色主题 -->
    <Theme name="Dark" type="Color" style="Dark"/>

    <!-- ===================== 基础灰度体系（Win11 25H2 深色标准） ===================== -->
    <!-- 核心：按明度分级，适配深色控件底层，避免过亮/过暗导致视觉疲劳 -->
    <TextColor name="color_white" value="#FFFFFFFF" comment_cn="高亮文本/按钮文字" comment_en="Highlight text/button text"/>
    <TextColor name="color_black" value="#FF1E1E1E" comment_cn="深色模式底层背景" comment_en="Dark mode base background"/>
    <TextColor name="color_gray" value="#FF9CA3AF" comment_cn="次要文本/辅助说明" comment_en="Secondary text/auxiliary description"/>
    <TextColor name="color_gray_light" value="#FF2D2D30" comment_cn="边框/一级分割线" comment_en="Border/level 1 split line"/>
    <TextColor name="color_gray_dark" value="#FF4B5563" comment_cn="禁用/次要背景" comment_en="Disabled/secondary background"/>
    <TextColor name="color_gray_deep" value="#FF111827" comment_cn="最深层背景" comment_en="Deepest layer background"/>
    <TextColor name="color_gray_light_deep" value="#FF6B7280" comment_cn="禁用文本" comment_en="Disabled text"/>

    <!-- ===================== 主题强调色体系（Win11 25H2 深色交互） ===================== -->
    <TextColor name="color_green" value="#FF10B981" comment_cn="成功/完成状态" comment_en="Success/completed status"/>
    <TextColor name="color_green_light" value="#FF34D399" comment_cn="绿色系hover" comment_en="Green hover state"/>
    <TextColor name="color_blue" value="#FF3B82F6" comment_cn="聚焦/选中/核心强调" comment_en="Focus/selected/core emphasis"/>
    <TextColor name="color_red" value="#FFEF4444" comment_cn="错误/警告/关闭按钮" comment_en="Error/warning/close button"/>
    <TextColor name="color_red_light" value="#FF6B7280" comment_cn="红色系hover" comment_en="Red hover state"/>
    <TextColor name="color_red_deep" value="#FFDC2626" comment_cn="红色系pressed" comment_en="Red pressed state"/>
    <TextColor name="color_blue_light" value="#FF60A5FA" comment_cn="蓝色系hover" comment_en="Blue hover state"/>
    <TextColor name="color_blue_deep" value="#FF2563EB" comment_cn="蓝色系pressed" comment_en="Blue pressed state"/>

    <!-- ===================== 文本颜色（Win11 深色文本层级） ===================== -->
    <TextColor name="text_default" value="#FFE5E7EB" comment_cn="主要文本/浅灰白" comment_en="Primary text/light gray white"/>
    <TextColor name="text_disabled" value="#FF6B7280" comment_cn="禁用文本/弱化显示" comment_en="Disabled text/weak display"/>
    <TextColor name="text_link_normal" value="#FF3B82F6" comment_cn="链接默认状态" comment_en="Link normal state"/>
    <TextColor name="text_link_hover" value="#FF60A5FA" comment_cn="链接悬浮状态" comment_en="Link hover state"/>
    <TextColor name="text_link_pressed" value="#FF2563EB" comment_cn="链接点击状态" comment_en="Link pressed state"/>
    <TextColor name="text_menu_bar" value="#FFE5E7EB" comment_cn="菜单栏文本" comment_en="Menu bar text"/>

    <!-- ===================== 背景颜色（深色层级划分） ===================== -->
    <TextColor name="border_window" value="#FF444444" comment_cn="窗口边框/深灰" comment_en="Window border/dark gray"/>
    <TextColor name="bg_window_dark" value="#FF1A1A1A" comment_cn="主窗口/面板背景" comment_en="Main window/panel background"/>
    <TextColor name="bg_window_light" value="#FF202020" comment_cn="卡片/弹窗背景" comment_en="Card/popup background"/>
    <TextColor name="bg_titlebar" value="#FF1A1A1A" comment_cn="标题栏背景" comment_en="Title bar background"/>
    <TextColor name="bg_menu" value="#FF252525" comment_cn="下拉/右键菜单背景" comment_en="Dropdown/context menu background"/>
    <TextColor name="bg_menu_item_hover" value="#FF333333" comment_cn="菜单项悬浮" comment_en="Menu item hover"/>
    <TextColor name="bg_menu_item_selected" value="#FF3A3A3A" comment_cn="菜单项选中" comment_en="Menu item selected"/>
    <TextColor name="bg_list_item_hover" value="#FF333333" comment_cn="列表项悬浮" comment_en="List item hover"/>
    <TextColor name="bg_list_item_selected" value="#FF3A3A3A" comment_cn="列表项选中" comment_en="List item selected"/>
    <TextColor name="bg_menu_bar" value="#FF1A1A1A" comment_cn="菜单栏背景" comment_en="Menu bar background"/>
    <TextColor name="bg_menu_bar_hover" value="#FF333333" comment_cn="菜单栏项悬浮" comment_en="Menu bar item hover"/>
    <TextColor name="bg_menu_bar_pressed" value="#FF3A3A3A" comment_cn="菜单栏项点击" comment_en="Menu bar item pressed"/>

    <!-- ===================== 通用控件颜色 ===================== -->
    <TextColor name="color_progress" value="#FF3B82F6" comment_cn="进度条填充/滑块主色" comment_en="Progress bar fill/slider main color"/>
    <TextColor name="color_splitline_level1" value="#FF2D2D30" comment_cn="一级分割线/主要区域分隔" comment_en="Level 1 split line/main area separator"/>
    <TextColor name="color_splitline_level2" value="#FF202020" comment_cn="二级分割线/次要区域分隔" comment_en="Level 2 split line/secondary area separator"/>
    <TextColor name="color_splitline_group_box" value="#FF444444" comment_cn="分组框分割线" comment_en="Group box split line"/>
    
    <!-- Split分割线/拖动条 -->
    <TextColor name="bg_split_normal" value="#FF2D2D30" comment_cn="分割线静态状态" comment_en="Split line normal state"/>
    <TextColor name="bg_split_hover" value="#FF444444" comment_cn="分割线悬浮状态" comment_en="Split line hover state"/>
    <TextColor name="bg_split_pressed" value="#FF555555" comment_cn="分割线拖动状态" comment_en="Split line dragging state"/>
    <TextColor name="bg_split_disabled" value="#FF2D2D30" comment_cn="分割线禁用状态" comment_en="Split line disabled state"/>

    <!-- 编辑框（Win11深色规范：暗边框+聚焦蓝下划线） -->
    <TextColor name="bg_richedit" value="#FF252525" comment_cn="编辑框默认背景" comment_en="RichEdit default background"/>
    <TextColor name="bg_richedit_caret" value="#FFE5E7EB" comment_cn="编辑框光标颜色" comment_en="RichEdit caret color"/>
    <TextColor name="text_richedit_prompt" value="#FF6B7280" comment_cn="编辑框占位符文本" comment_en="RichEdit prompt text"/>
    <TextColor name="border_richedit_normal" value="#FF2D2D30" comment_cn="编辑框默认边框" comment_en="RichEdit normal border"/>
    <TextColor name="border_richedit_hover" value="#FF444444" comment_cn="编辑框悬浮边框" comment_en="RichEdit hover border"/>
    <TextColor name="border_richedit_focus" value="#FF2D2D30" comment_cn="编辑框聚焦边框" comment_en="RichEdit focus border"/>
    <TextColor name="border_richedit_focus_bottom" value="#FF3B82F6" comment_cn="编辑框聚焦下划线" comment_en="RichEdit focus bottom line"/>
    <TextColor name="bg_richedit_btn_normal" value="#FF252525" comment_cn="编辑框按钮默认背景" comment_en="RichEdit button normal bg"/>
    <TextColor name="bg_richedit_btn_hover" value="#FF333333" comment_cn="编辑框按钮悬浮背景" comment_en="RichEdit button hover bg"/>
    <TextColor name="bg_richedit_btn_pressed" value="#FF3A3A3A" comment_cn="编辑框按钮点击背景" comment_en="RichEdit button pressed bg"/>
    <TextColor name="border_richedit_btn" value="#FF2D2D30" comment_cn="编辑框按钮边框" comment_en="RichEdit button border"/>

    <!-- 窗口标题栏按钮（最小化/最大化/关闭） -->
    <TextColor name="bg_btn_window_hover" value="#FF333333" comment_cn="窗口按钮悬浮背景" comment_en="Window button hover bg"/>
    <TextColor name="bg_btn_window_pressed" value="#FF3A3A3A" comment_cn="窗口按钮点击背景" comment_en="Window button pressed bg"/>
    <TextColor name="bg_btn_window_close_hover" value="#FFEF4444" comment_cn="关闭按钮悬浮背景" comment_en="Close button hover bg"/>
    <TextColor name="bg_btn_window_close_pressed" value="#FFDC2626" comment_cn="关闭按钮点击背景" comment_en="Close button pressed bg"/>

    <!-- ===================== 按钮颜色（次要按钮：无强调色） ===================== -->
    <TextColor name="text_btn_normal" value="#FFE5E7EB" comment_cn="次要按钮默认文本" comment_en="Secondary button normal text"/>
    <TextColor name="text_btn_disabled" value="#FF6B7280" comment_cn="次要按钮禁用文本" comment_en="Secondary button disabled text"/>
    <TextColor name="bg_btn_normal" value="#FF252525" comment_cn="次要按钮默认背景" comment_en="Secondary button normal bg"/>
    <TextColor name="bg_btn_hover" value="#FF333333" comment_cn="次要按钮悬浮背景" comment_en="Secondary button hover bg"/>
    <TextColor name="bg_btn_pressed" value="#FF3A3A3A" comment_cn="次要按钮点击背景" comment_en="Secondary button pressed bg"/>
