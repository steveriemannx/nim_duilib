    <TextColor name="bg_primary_btn_disabled" value="#FF2E456B" comment_cn="主要按钮禁用背景" comment_en="Primary button disabled bg"/>
    <TextColor name="border_primary_btn_normal" value="#FF2563EB" comment_cn="主要按钮默认边框" comment_en="Primary button normal border"/>
    <TextColor name="border_primary_btn_hover" value="#FF2563EB" comment_cn="主要按钮悬浮边框" comment_en="Primary button hover border"/>
    <TextColor name="border_primary_btn_pressed" value="#FF1E57D9" comment_cn="主要按钮点击边框" comment_en="Primary button pressed border"/>
    <TextColor name="border_primary_btn_disabled" value="#FF2E456B" comment_cn="主要按钮禁用边框" comment_en="Primary button disabled border"/>

