<?xml version="1.0" encoding="UTF-8"?>
<Global>
    <!-- 主题基础配置：Win11 25H2 深色主题 | 类型为颜色主题 -->
    <Theme name="Dark" type="Color" style="Dark"/>

    <!-- ===================== 基础灰度体系（Win11 25H2 深色标准） ===================== -->
    <!-- 核心：按明度分级，适配深色控件底层，避免过亮/过暗导致视觉疲劳 -->
    <TextColor name="color_white" value="#FFFFFFFF"/>        <!-- 纯白：高亮文本/按钮文字 -->
    <TextColor name="color_black" value="#FF1E1E1E"/>        <!-- 近黑：深色模式底层背景 -->
    <TextColor name="color_gray" value="#FF9CA3AF"/>         <!-- 中性灰：次要文本/辅助说明 -->
    <TextColor name="color_gray_light" value="#FF2D2D30"/>   <!-- 浅灰：边框/一级分割线 -->
    <TextColor name="color_gray_dark" value="#FF4B5563"/>    <!-- 深灰：禁用/次要背景 -->
    <TextColor name="color_gray_deep" value="#FF111827"/>    <!-- 极深灰：最深层背景 -->
    <TextColor name="color_gray_light_deep" value="#FF6B7280"/> <!-- 浅深灰：禁用文本 -->

    <!-- ===================== 主题强调色体系（Win11 25H2 深色交互） ===================== -->
    <TextColor name="color_green" value="#FF10B981"/>        <!-- 系统绿：成功/完成状态 -->
    <TextColor name="color_green_light" value="#FF34D399"/>  <!-- 浅绿：绿色系hover -->
    <TextColor name="color_blue" value="#FF3B82F6"/>         <!-- 主蓝：聚焦/选中/核心强调 -->
    <TextColor name="color_red" value="#FFEF4444"/>          <!-- 系统红：错误/警告/关闭按钮 -->
    <TextColor name="color_red_light" value="#FF6B7280"/>    <!-- 浅红：红色系hover -->
    <TextColor name="color_red_deep" value="#FFDC2626"/>     <!-- 深红：红色系pressed -->
    <TextColor name="color_blue_light" value="#FF60A5FA"/>   <!-- 浅蓝：蓝色系hover -->
    <TextColor name="color_blue_deep" value="#FF2563EB"/>    <!-- 深蓝：蓝色系pressed -->

    <!-- ===================== 文本颜色（Win11 深色文本层级） ===================== -->
    <TextColor name="text_default" value="#FFE5E7EB"/>       <!-- 主要文本：浅灰白（核心可读） -->
    <TextColor name="text_disabled" value="#FF6B7280"/>      <!-- 禁用文本：弱化显示 -->
    <TextColor name="text_link_normal" value="#FF3B82F6"/>   <!-- 链接：默认 -->
    <TextColor name="text_link_hover" value="#FF60A5FA"/>    <!-- 链接：悬浮 -->
    <TextColor name="text_link_pressed" value="#FF2563EB"/>  <!-- 链接：点击中 -->
    <TextColor name="text_menu_bar" value="#FFE5E7EB"/>      <!-- 菜单栏文本：同主要文本 -->

    <!-- ===================== 背景颜色（深色层级划分） ===================== -->
    <TextColor name="border_window" value="#FF444444"/>      <!-- 窗口边框：深灰，避免融于背景 -->
    <TextColor name="bg_window_dark" value="#FF1A1A1A"/>     <!-- 窗口背景：主窗口/面板（最深） -->
    <TextColor name="bg_window_light" value="#FF202020"/>    <!-- 窗口背景：卡片/弹窗（浅一级） -->
    <TextColor name="bg_titlebar" value="#FF1A1A1A"/>        <!-- 标题栏背景：同主窗口 -->
    <TextColor name="bg_menu" value="#FF252525"/>            <!-- 菜单背景：下拉/右键菜单 -->
    <TextColor name="bg_menu_item_hover" value="#FF333333"/> <!-- 菜单项：悬浮 -->
    <TextColor name="bg_menu_item_selected" value="#FF3A3A3A"/> <!-- 菜单项：选中 -->
    <TextColor name="bg_list_item_hover" value="#FF333333"/> <!-- 列表项：悬浮（同菜单项） -->
    <TextColor name="bg_list_item_selected" value="#FF3A3A3A"/> <!-- 列表项：选中（同菜单项） -->
    <TextColor name="bg_menu_bar" value="#FF1A1A1A"/>        <!-- 菜单栏背景：同主窗口 -->
    <TextColor name="bg_menu_bar_hover" value="#FF333333"/>  <!-- 菜单栏项：悬浮 -->
    <TextColor name="bg_menu_bar_pressed" value="#FF3A3A3A"/> <!-- 菜单栏项：点击 -->

    <!-- ===================== 通用控件颜色 ===================== -->
    <TextColor name="color_progress" value="#FF3B82F6"/>     <!-- 进度条：填充/滑块主色 -->
    <TextColor name="color_splitline_level1" value="#FF2D2D30"/> <!-- 一级分割线：主要区域分隔 -->
    <TextColor name="color_splitline_level2" value="#FF202020"/> <!-- 二级分割线：次要区域分隔 -->
    <TextColor name="color_splitline_group_box" value="#FF444444"/> <!-- 分组框分割线 -->
    
    <!-- Split分割线/拖动条 -->
    <TextColor name="bg_split_normal" value="#FF2D2D30"/>    <!-- 静态 -->
    <TextColor name="bg_split_hover" value="#FF444444"/>     <!-- 悬浮 -->
    <TextColor name="bg_split_pressed" value="#FF555555"/>   <!-- 拖动中 -->
    <TextColor name="bg_split_disabled" value="#FF2D2D30"/>  <!-- 禁用（同静态） -->

    <!-- 编辑框（Win11深色规范：暗边框+聚焦蓝下划线） -->
    <TextColor name="bg_richedit" value="#FF252525"/>        <!-- 背景：输入框默认 -->
    <TextColor name="bg_richedit_caret" value="#FFE5E7EB"/>  <!-- 光标：浅灰白（保证可见） -->
    <TextColor name="text_richedit_prompt" value="#FF6B7280"/> <!-- 占位符文本 -->
    <TextColor name="border_richedit_normal" value="#FF2D2D30"/> <!-- 边框：默认 -->
    <TextColor name="border_richedit_hover" value="#FF444444"/> <!-- 边框：悬浮 -->
    <TextColor name="border_richedit_focus" value="#FF2D2D30"/> <!-- 边框：聚焦（不变） -->
    <TextColor name="border_richedit_focus_bottom" value="#FF3B82F6"/> <!-- 聚焦下划线：主蓝 -->
    <TextColor name="bg_richedit_btn_normal" value="#FF252525"/> <!-- 编辑框按钮：默认 -->
    <TextColor name="bg_richedit_btn_hover" value="#FF333333"/> <!-- 编辑框按钮：悬浮 -->
    <TextColor name="bg_richedit_btn_pressed" value="#FF3A3A3A"/> <!-- 编辑框按钮：点击 -->
    <TextColor name="border_richedit_btn" value="#FF2D2D30"/> <!-- 编辑框按钮：边框 -->

    <!-- 窗口标题栏按钮（最小化/最大化/关闭） -->
    <TextColor name="bg_btn_window_hover" value="#FF333333"/> <!-- 通用按钮：悬浮 -->
    <TextColor name="bg_btn_window_pressed" value="#FF3A3A3A"/> <!-- 通用按钮：点击 -->
    <TextColor name="bg_btn_window_close_hover" value="#FFEF4444"/> <!-- 关闭按钮：悬浮 -->
    <TextColor name="bg_btn_window_close_pressed" value="#FFDC2626"/> <!-- 关闭按钮：点击 -->

    <!-- ===================== 按钮颜色（次要按钮：无强调色） ===================== -->
    <TextColor name="text_btn_normal" value="#FFE5E7EB"/>    <!-- 文本：默认 -->
    <TextColor name="text_btn_disabled" value="#FF6B7280"/>   <!-- 文本：禁用（弱化） -->
    <TextColor name="bg_btn_normal" value="#FF252525"/>      <!-- 背景：默认（暗灰） -->
    <TextColor name="bg_btn_hover" value="#FF333333"/>       <!-- 背景：悬浮（亮一点） -->
    <TextColor name="bg_btn_pressed" value="#FF3A3A3A"/>     <!-- 背景：点击（更亮） -->
    <TextColor name="bg_btn_disabled" value="#FF252525"/>    <!-- 背景：禁用（同默认，仅文本变灰） -->
    <TextColor name="border_btn_normal" value="#FF2D2D30"/>  <!-- 边框：默认 -->
    <TextColor name="border_btn_hover" value="#FF444444"/>   <!-- 边框：悬浮 -->
    <TextColor name="border_btn_pressed" value="#FF555555"/> <!-- 边框：点击 -->
    <TextColor name="border_btn_disabled" value="#FF2A2A2A"/> <!-- 边框：禁用（浅于默认） -->

    <!-- ===================== 按钮颜色（主要按钮：强调色） ===================== -->
    <TextColor name="text_primary_btn_normal" value="#FFFFFFFF"/>    <!-- 文本：默认（纯白） -->
    <TextColor name="text_primary_btn_disabled" value="#FF94BFFF"/>   <!-- 文本：禁用（浅蓝白） -->
    <TextColor name="bg_primary_btn_normal" value="#FF3B82F6"/>      <!-- 背景：默认（主蓝） -->
    <TextColor name="bg_primary_btn_hover" value="#FF4A90F6"/>       <!-- 背景：悬浮（亮一点） -->
    <TextColor name="bg_primary_btn_pressed" value="#FF2563EB"/>     <!-- 背景：点击（深一点） -->
    <TextColor name="bg_primary_btn_disabled" value="#FF2E456B"/>    <!-- 背景：禁用（低饱和蓝） -->
    <TextColor name="border_primary_btn_normal" value="#FF2563EB"/>   <!-- 边框：默认（深蓝） -->
    <TextColor name="border_primary_btn_hover" value="#FF2563EB"/>    <!-- 边框：悬浮（同默认） -->
    <TextColor name="border_primary_btn_pressed" value="#FF1E57D9"/>  <!-- 边框：点击（更深） -->
    <TextColor name="border_primary_btn_disabled" value="#FF2E456B"/> <!-- 边框：禁用（同背景） -->

    <!-- ===================== 专用控件颜色 ===================== -->
    <!-- 全屏按钮 -->
    <TextColor name="bg_btn_exit_fullscreen" value="#FF3B82F6"/> <!-- 背景：主蓝 -->
    <TextColor name="text_btn_exit_fullscreen" value="#FFFFFFFF"/> <!-- 文本：纯白 -->

    <!-- 下拉框（ComboBox） -->
    <TextColor name="bg_combo" value="#FF252525"/>           <!-- 背景：默认 -->
    <TextColor name="border_combo_normal" value="#FF2D2D30"/> <!-- 边框：默认 -->
    <TextColor name="border_combo_hover" value="#FF444444"/> <!-- 边框：悬浮 -->
    <TextColor name="bg_combo_btn_hover" value="#FF333333"/> <!-- 下拉按钮：悬浮 -->
    <TextColor name="bg_combo_btn_pressed" value="#FF3A3A3A"/> <!-- 下拉按钮：点击 -->

    <!-- 列表控件（ListCtrl） -->
    <TextColor name="bg_list_ctrl_header" value="#FF202020"/> <!-- 表头：背景 -->
    <TextColor name="bg_list_ctrl_header_hover" value="#FF333333"/> <!-- 表头：悬浮 -->
    <TextColor name="bg_list_ctrl_header_pressed" value="#FF3A3A3A"/> <!-- 表头：点击 -->
    <TextColor name="bg_list_ctrl_header_split" value="#FF444444"/> <!-- 表头：分割线 -->
    <TextColor name="bg_list_ctrl_view_split" value="#FF444444"/> <!-- 表格：分割线 -->
    <TextColor name="bg_list_ctrl_view" value="#FF252525"/>   <!-- 视图：背景 -->
    <TextColor name="bg_list_ctrl_frame_selected" value="#FF416385"/> <!-- 选中项：外框背景 -->
    <TextColor name="border_list_ctrl_frame_selected" value="#FF3B82F6"/> <!-- 选中项：外框边框 -->
    <TextColor name="bg_list_ctrl_item_hover" value="#FF434343"/> <!-- 列表项：悬浮（加深，提升辨识度） -->
    <TextColor name="bg_list_ctrl_item_pressed" value="#FF3A3A3A"/> <!-- 列表项：点击 -->
    <TextColor name="bg_list_ctrl_item_selected" value="#FF4A4A4A"/> <!-- 列表项：选中 -->

    <!-- 标签页（TabCtrl） -->
    <TextColor name="bg_tab_ctrl" value="#FF1A1A1A"/>        <!-- 背景：整体 -->
    <TextColor name="bg_tab_ctrl_item_hover" value="#FF3F3F3F"/> <!-- 标签项：悬浮 -->
    <TextColor name="bg_tab_ctrl_item_pressed" value="#FF3A3A3A"/> <!-- 标签项：点击 -->
    <TextColor name="bg_tab_ctrl_item_selected" value="#FF333333"/> <!-- 标签项：选中 -->
    <TextColor name="bg_tab_ctrl_item_close_hover" value="#FF3F3F3F"/> <!-- 关闭按钮：悬浮 -->
    <TextColor name="bg_tab_ctrl_item_close_pressed" value="#FF3A3A3A"/> <!-- 关闭按钮：点击 -->
    <TextColor name="border_tab_ctrl_item" value="#FF2D2D30"/> <!-- 标签项：边框 -->

    <!-- 地址栏（AddressBar） -->
    <TextColor name="border_address_bar" value="#FF2D2D30"/>     <!-- 边框：默认 -->
    <TextColor name="bg_address_bar" value="#FF252525"/>         <!-- 背景：默认 -->    
    <TextColor name="bg_address_bar_btn_hover" value="#FF333333"/> <!-- 按钮：悬浮 -->
    <TextColor name="bg_address_bar_btn_pressed" value="#FF3A3A3A"/> <!-- 按钮：点击 -->

    <!-- 属性页（PropertyGrid） -->
    <TextColor name="bg_property_grid_header" value="#FF252525"/>            <!-- 分组表头：背景 -->    
    <TextColor name="bg_property_grid_header_split" value="#FF3D3D3D"/>      <!-- 分组表头：分割线 -->
    <TextColor name="border_property_grid_header" value="#FF2D2D30"/>        <!-- 分组表头：边框 -->    
    <TextColor name="text_property_grid_header" value="#FFE5E7EB"/>          <!-- 分组表头：文本（默认） -->
    <TextColor name="text_property_grid_header_disabled" value="#FF6B7280"/> <!-- 分组表头：文本（禁用） -->
    <TextColor name="bg_property_grid_group" value="#FF1E1E1E"/>             <!-- 分组：背景（最深，区分行） -->
    <TextColor name="bg_property_grid_property" value="#FF252525"/>         <!-- 属性行：背景 -->    
    <TextColor name="bg_property_grid_property_name" value="#FF252525"/>    <!-- 属性名：背景（同值列） -->    
    <TextColor name="bg_property_grid_property_value" value="#FF252525"/>   <!-- 属性值：背景 -->    
    <TextColor name="bg_property_grid_line" value="#FF3D3D3D"/>              <!-- 网格：分割线 -->
</Global>