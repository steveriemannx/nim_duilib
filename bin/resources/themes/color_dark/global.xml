    <TextColor name="bg_tab_ctrl_item_hover" value="#FF3F3F3F" comment_cn="标签项悬浮背景" comment_en="Tab item hover bg"/>
    <TextColor name="bg_tab_ctrl_item_pressed" value="#FF3A3A3A" comment_cn="标签项点击背景" comment_en="Tab item pressed bg"/>
