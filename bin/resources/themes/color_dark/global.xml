    <TextColor name="bg_btn_exit_fullscreen" value="#FF3B82F6" comment_cn="退出全屏按钮背景" comment_en="Exit fullscreen button bg"/>
    <TextColor name="text_btn_exit_fullscreen" value="#FFFFFFFF" comment_cn="退出全屏按钮文本" comment_en="Exit fullscreen button text"/>

    <!-- 下拉框（ComboBox） -->
