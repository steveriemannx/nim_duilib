    <TextColor name="border_combo_normal" value="#FF2D2D30" comment_cn="下拉框默认边框" comment_en="ComboBox normal border"/>
    <TextColor name="border_combo_hover" value="#FF444444" comment_cn="下拉框悬浮边框" comment_en="ComboBox hover border"/>
    <TextColor name="bg_combo_btn_hover" value="#FF333333" comment_cn="下拉按钮悬浮背景" comment_en="Combo button hover bg"/>
    <TextColor name="bg_combo_btn_pressed" value="#FF3A3A3A" comment_cn="下拉按钮点击背景" comment_en="Combo button pressed bg"/>

