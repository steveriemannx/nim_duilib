    <TextColor name="bg_list_ctrl_header_hover" value="#FF333333" comment_cn="列表表头悬浮背景" comment_en="List header hover bg"/>
    <TextColor name="bg_list_ctrl_header_pressed" value="#FF3A3A3A" comment_cn="列表表头点击背景" comment_en="List header pressed bg"/>
