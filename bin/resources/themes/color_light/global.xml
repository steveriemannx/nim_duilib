<?xml version="1.0" encoding="UTF-8"?>
<Global>
    <!-- 主题基础配置：Win11 25H2 浅色主题 | 类型为颜色主题 -->
    <Theme name="Light" type="Color" style="Light"/>

    <!-- ===================== 基础灰度体系（Win11 25H2 官方标准） ===================== -->
    <!-- 核心：按明度分级，适配控件底层样式，避免纯黑/纯白刺眼 -->
    <TextColor name="color_white" value="#FFFFFFFF"/>        <!-- 纯白：高亮文本/按钮背景 -->
    <TextColor name="color_black" value="#FF1E1E1E"/>        <!-- 近黑：系统默认文本（替代纯黑，Win11规范） -->
    <TextColor name="color_gray" value="#FF6B7280"/>         <!-- 中性灰：次要文本/辅助说明 -->
    <TextColor name="color_gray_light" value="#FFE5E7EB"/>   <!-- 浅灰：默认边框/一级分割线 -->
    <TextColor name="color_gray_dark" value="#FF4B5563"/>    <!-- 深灰：次要背景/禁用控件底色 -->
    <TextColor name="color_gray_deep" value="#FF374151"/>    <!-- 极深灰：重度强调背景/阴影 -->
    <TextColor name="color_gray_light_deep" value="#FF9CA3AF"/> <!-- 浅深灰：禁用文本/提示文本 -->

    <!-- ===================== 主题强调色体系（Win11 25H2 交互状态） ===================== -->
    <TextColor name="color_green" value="#FF059669"/>        <!-- 系统绿：成功/完成状态 -->
    <TextColor name="color_green_light" value="#FF34D399"/>  <!-- 浅绿：绿色系hover -->
    <TextColor name="color_blue" value="#FF0078D4"/>         <!-- 系统主蓝：聚焦/选中/核心强调 -->
    <TextColor name="color_red" value="#FFDC2626"/>          <!-- 系统红：错误/警告/关闭按钮 -->
    <TextColor name="color_red_light" value="#FFF87171"/>    <!-- 浅红：红色系hover -->
    <TextColor name="color_red_deep" value="#FFB91C1C"/>     <!-- 深红：红色系pressed -->
    <TextColor name="color_blue_light" value="#FF3D9EFF"/>   <!-- 浅蓝：蓝色系hover -->
    <TextColor name="color_blue_deep" value="#FF005A9E"/>    <!-- 深蓝：蓝色系pressed -->

    <!-- ===================== 文本颜色（Win11 文本层级规范） ===================== -->
    <TextColor name="text_default" value="#FF1E1E1E"/>       <!-- 主要文本：正文/标题/控件默认 -->
    <TextColor name="text_disabled" value="#FF888888"/>      <!-- 禁用文本：不可交互控件 -->
    <TextColor name="text_link_normal" value="#FF0078D4"/>   <!-- 链接：默认 -->
    <TextColor name="text_link_hover" value="#FF005A9E"/>    <!-- 链接：悬浮 -->
    <TextColor name="text_link_pressed" value="#FF004578"/>  <!-- 链接：点击中 -->
    <TextColor name="text_menu_bar" value="#FF1E1E1E"/>      <!-- 菜单栏文本：同主要文本 -->

    <!-- ===================== 背景颜色（按层级划分） ===================== -->
    <TextColor name="border_window" value="#FFB5B5B5"/>      <!-- 窗口边框：中性浅灰 -->
    <TextColor name="bg_window_dark" value="#FFF2F2F2"/>     <!-- 窗口背景：主窗口/面板（深一级） -->
    <TextColor name="bg_window_light" value="#FFFFFFFF"/>    <!-- 窗口背景：卡片/弹窗（浅一级） -->    
    <TextColor name="bg_titlebar" value="#FFEFEFEF"/>        <!-- 标题栏背景 -->
    <TextColor name="bg_menu" value="#FFFFFFFF"/>            <!-- 菜单背景：下拉/右键菜单 -->
    <TextColor name="bg_menu_item_hover" value="#FFE6F0FF"/> <!-- 菜单项：悬浮 -->
    <TextColor name="bg_menu_item_selected" value="#FFCCE5FF"/> <!-- 菜单项：选中 -->
    <TextColor name="bg_list_item_hover" value="#FFE6F0FF"/> <!-- 列表项：悬浮（同菜单项） -->
    <TextColor name="bg_list_item_selected" value="#FFCCE5FF"/> <!-- 列表项：选中（同菜单项） -->
    <TextColor name="bg_menu_bar" value="#FFF2F2F2"/>        <!-- 菜单栏背景：比窗口深，区分层级 -->
    <TextColor name="bg_menu_bar_hover" value="#FFE6F0FF"/>  <!-- 菜单栏项：悬浮 -->
    <TextColor name="bg_menu_bar_pressed" value="#FFCCE5FF"/> <!-- 菜单栏项：点击 -->

    <!-- ===================== 通用控件颜色 ===================== -->
    <TextColor name="color_progress" value="#FF0078D4"/>     <!-- 进度条：填充/滑块主色 -->
    <TextColor name="color_splitline_level1" value="#FFE5E7EB"/> <!-- 一级分割线：主要区域分隔 -->
    <TextColor name="color_splitline_level2" value="#FFF5F5F5"/> <!-- 二级分割线：次要区域分隔 -->
    <TextColor name="color_splitline_group_box" value="#FFE0E0E0"/> <!-- 分组框分割线 -->
    
    <!-- Split分割线/拖动条 -->
    <TextColor name="bg_split_normal" value="#FFE5E7EB"/>    <!-- 静态 -->
    <TextColor name="bg_split_hover" value="#FFD1D5DB"/>     <!-- 悬浮 -->
    <TextColor name="bg_split_pressed" value="#FF9CA3AF"/>   <!-- 拖动中 -->
    <TextColor name="bg_split_disabled" value="#FFE5E7EB"/>  <!-- 禁用（同静态） -->

    <!-- 编辑框（Win11规范：灰边框+聚焦蓝下划线） -->
    <TextColor name="bg_richedit" value="#FFFFFFFF"/>        <!-- 背景：输入框默认 -->
    <TextColor name="bg_richedit_caret" value="#FF1E1E1E"/>  <!-- 光标：近黑（避免纯黑刺眼） -->
    <TextColor name="text_richedit_prompt" value="#FF888888"/> <!-- 占位符文本 -->
    <TextColor name="border_richedit_normal" value="#FFD1D5DB"/> <!-- 边框：默认 -->
    <TextColor name="border_richedit_hover" value="#FF9CA3AF"/> <!-- 边框：悬浮 -->
    <TextColor name="border_richedit_focus" value="#FFD1D5DB"/> <!-- 边框：聚焦（不变） -->
    <TextColor name="border_richedit_focus_bottom" value="#FF0078D4"/> <!-- 聚焦下划线：主蓝 -->
    <TextColor name="bg_richedit_btn_normal" value="#FFF5F5F5"/> <!-- 编辑框按钮：默认 -->
    <TextColor name="bg_richedit_btn_hover" value="#FFE6F0FF"/> <!-- 编辑框按钮：悬浮 -->
    <TextColor name="bg_richedit_btn_pressed" value="#FFCCE5FF"/> <!-- 编辑框按钮：点击 -->
    <TextColor name="border_richedit_btn" value="#FFD1D5DB"/> <!-- 编辑框按钮：边框 -->

    <!-- 窗口标题栏按钮（最小化/最大化/关闭） -->
    <TextColor name="bg_btn_window_hover" value="#FFD5D5D5"/> <!-- 通用按钮：悬浮 -->
    <TextColor name="bg_btn_window_pressed" value="#FFC0C0C0"/> <!-- 通用按钮：点击 -->
    <TextColor name="bg_btn_window_close_hover" value="#FFDC2626"/> <!-- 关闭按钮：悬浮 -->
    <TextColor name="bg_btn_window_close_pressed" value="#FFB91C1C"/> <!-- 关闭按钮：点击 -->

    <!-- ===================== 按钮颜色（次要按钮：无强调色） ===================== -->
    <TextColor name="text_btn_normal" value="#FF1E1E1E"/>    <!-- 文本：默认 -->
    <TextColor name="text_btn_disabled" value="#FF909090"/>   <!-- 文本：禁用（加深，提升可读性） -->
    <TextColor name="bg_btn_normal" value="#FFEEEEEE"/>      <!-- 背景：默认（浅灰，强化轮廓） -->
    <TextColor name="bg_btn_hover" value="#FFDCEAFF"/>       <!-- 背景：悬浮（浅蓝，反馈明显） -->
    <TextColor name="bg_btn_pressed" value="#FFBFD7FF"/>     <!-- 背景：点击（中蓝，反馈更强） -->
    <TextColor name="bg_btn_disabled" value="#FFEEEEEE"/>    <!-- 背景：禁用（同默认，仅文本变灰） -->
    <TextColor name="border_btn_normal" value="#FFD1D5DB"/>  <!-- 边框：默认 -->
    <TextColor name="border_btn_hover" value="#FF94BFFF"/>   <!-- 边框：悬浮 -->
    <TextColor name="border_btn_pressed" value="#FF60A5FA"/> <!-- 边框：点击 -->
    <TextColor name="border_btn_disabled" value="#FFE5E7EB"/> <!-- 边框：禁用（浅于默认） -->

    <!-- ===================== 按钮颜色（主要按钮：强调色） ===================== -->
    <TextColor name="text_primary_btn_normal" value="#FFFFFFFF"/>    <!-- 文本：默认（纯白） -->
    <TextColor name="text_primary_btn_disabled" value="#FFBFD7FF"/>   <!-- 文本：禁用（浅蓝白） -->
    <TextColor name="bg_primary_btn_normal" value="#FF0078D4"/>      <!-- 背景：默认（主蓝） -->
    <TextColor name="bg_primary_btn_hover" value="#FF1084E3"/>       <!-- 背景：悬浮（亮一点） -->
    <TextColor name="bg_primary_btn_pressed" value="#FF0066B2"/>     <!-- 背景：点击（深一点） -->
    <TextColor name="bg_primary_btn_disabled" value="#FF78A3D1"/>    <!-- 背景：禁用（低饱和蓝） -->
    <TextColor name="border_primary_btn_normal" value="#FF005A9E"/>   <!-- 边框：默认（深蓝） -->
    <TextColor name="border_primary_btn_hover" value="#FF0063B0"/>    <!-- 边框：悬浮 -->
    <TextColor name="border_primary_btn_pressed" value="#FF004F8A"/>  <!-- 边框：点击 -->
    <TextColor name="border_primary_btn_disabled" value="#FF78A3D1"/> <!-- 边框：禁用（同背景） -->

    <!-- ===================== 专用控件颜色 ===================== -->
    <!-- 全屏按钮 -->
    <TextColor name="bg_btn_exit_fullscreen" value="#FF0078D4"/> <!-- 背景：主蓝 -->
    <TextColor name="text_btn_exit_fullscreen" value="#FFFFFFFF"/> <!-- 文本：纯白 -->

    <!-- 下拉框（ComboBox） -->
    <TextColor name="bg_combo" value="#FFFFFFFF"/>           <!-- 背景：默认 -->
    <TextColor name="border_combo_normal" value="#FFD1D5DB"/> <!-- 边框：默认 -->
    <TextColor name="border_combo_hover" value="#FF9CA3AF"/> <!-- 边框：悬浮 -->
    <TextColor name="bg_combo_btn_hover" value="#FFE6F0FF"/> <!-- 下拉按钮：悬浮 -->
    <TextColor name="bg_combo_btn_pressed" value="#FFCCE5FF"/> <!-- 下拉按钮：点击 -->

    <!-- 列表控件（ListCtrl） -->
    <TextColor name="bg_list_ctrl_header" value="#FFF5F5F5"/> <!-- 表头：背景 -->
    <TextColor name="bg_list_ctrl_header_hover" value="#FFE6F0FF"/> <!-- 表头：悬浮 -->
    <TextColor name="bg_list_ctrl_header_pressed" value="#FFCCE5FF"/> <!-- 表头：点击 -->
    <TextColor name="bg_list_ctrl_header_split" value="#FFE5E7EB"/> <!-- 表头：分割线 -->
    <TextColor name="bg_list_ctrl_view_split" value="#FFE5E7EB"/> <!-- 表格：分割线 -->
    <TextColor name="bg_list_ctrl_view" value="#FFFFFFFF"/>   <!-- 视图：背景 -->
    <TextColor name="bg_list_ctrl_frame_selected" value="#FF88BDEE"/> <!-- 选中项：外框背景 -->
    <TextColor name="border_list_ctrl_frame_selected" value="#FF0078D4"/> <!-- 选中项：外框边框 -->
    <TextColor name="bg_list_ctrl_item_hover" value="#FFE6F0FF"/> <!-- 列表项：悬浮 -->
    <TextColor name="bg_list_ctrl_item_pressed" value="#FFCCE5FF"/> <!-- 列表项：点击 -->
    <TextColor name="bg_list_ctrl_item_selected" value="#FFCCE5FF"/> <!-- 列表项：选中 -->

    <!-- 标签页（TabCtrl） -->
    <TextColor name="bg_tab_ctrl" value="#FFF0F0F0"/>        <!-- 背景：整体 -->
    <TextColor name="bg_tab_ctrl_item_hover" value="#FFB7B7B7"/> <!-- 标签项：悬浮 -->
    <TextColor name="bg_tab_ctrl_item_pressed" value="#FFCCE5FF"/> <!-- 标签项：点击 -->
    <TextColor name="bg_tab_ctrl_item_selected" value="#FFFFFFFF"/> <!-- 标签项：选中 -->
    <TextColor name="bg_tab_ctrl_item_close_hover" value="#FFE6F0FF"/> <!-- 关闭按钮：悬浮 -->
    <TextColor name="bg_tab_ctrl_item_close_pressed" value="#FFCCE5FF"/> <!-- 关闭按钮：点击 -->
    <TextColor name="border_tab_ctrl_item" value="#FFD1D5DB"/> <!-- 标签项：边框 -->

    <!-- 地址栏（AddressBar） -->
    <TextColor name="border_address_bar" value="#FFD1D5DB"/>     <!-- 边框：默认 -->
    <TextColor name="bg_address_bar" value="#FFFFFFFF"/>         <!-- 背景：默认 -->    
    <TextColor name="bg_address_bar_btn_hover" value="#FFE6F0FF"/> <!-- 按钮：悬浮 -->
    <TextColor name="bg_address_bar_btn_pressed" value="#FFCCE5FF"/> <!-- 按钮：点击 -->

    <!-- 属性页（PropertyGrid） -->
    <TextColor name="bg_property_grid_header" value="#FFE0E0E0"/>            <!-- 分组表头：背景 -->    
    <TextColor name="bg_property_grid_header_split" value="#FFA9A9A9"/>      <!-- 分组表头：分割线 -->
    <TextColor name="border_property_grid_header" value="#FFD1D5DB"/>        <!-- 分组表头：边框 -->    
    <TextColor name="text_property_grid_header" value="#FF1E1E1E"/>          <!-- 分组表头：文本（默认） -->
    <TextColor name="text_property_grid_header_disabled" value="#FF707070"/> <!-- 分组表头：文本（禁用） -->
    <TextColor name="bg_property_grid_group" value="#FFEFEFEF"/>             <!-- 分组：背景（加深，区分行） -->
    <TextColor name="bg_property_grid_property" value="#FFFFFFFF"/>         <!-- 属性行：背景 -->    
    <TextColor name="bg_property_grid_property_name" value="#FFFFFFFF"/>    <!-- 属性名：背景（同值列） -->    
    <TextColor name="bg_property_grid_property_value" value="#FFFFFFFF"/>   <!-- 属性值：背景 -->    
    <TextColor name="bg_property_grid_line" value="#FFD1D5DB"/>              <!-- 网格：分割线 -->
</Global>